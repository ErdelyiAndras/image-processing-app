{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "generator-msvc",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "generator-ninja-clang-cl",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows",
                "CMAKE_CXX_COMPILER":   "clang-cl",
                "CMAKE_C_COMPILER":     "clang-cl"
            }
        },
        {
            "name": "msvc",
            "inherits": ["base", "generator-msvc"],
            "binaryDir": "${sourceDir}/build-msvc",
            "cacheVariables": {
                "BUILD_TESTS": "ON"
            }
        },
        {
            "name": "clang-cl-debug",
            "inherits": ["base", "generator-ninja-clang-cl"],
            "binaryDir": "${sourceDir}/build-clang-cl-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "clang-cl-release",
            "inherits": ["base", "generator-ninja-clang-cl"],
            "binaryDir": "${sourceDir}/build-clang-cl-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "clang-cl-warnings-as-errors",
            "inherits": ["base", "generator-ninja-clang-cl"],
            "binaryDir": "${sourceDir}/build-clang-cl-warnings-as-errors",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "WarningsAsErrors"
            }
        },
        {
            "name": "clang-cl-tests",
            "inherits": ["base", "generator-ninja-clang-cl"],
            "binaryDir": "${sourceDir}/build-clang-cl-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Tests",
                "BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc-debug",
            "configurePreset": "msvc",
            "configuration": "Debug",
            "targets": ["image-processing-app"]
        },
        {
            "name": "msvc-release",
            "configurePreset": "msvc",
            "configuration": "Release",
            "targets": ["image-processing-app"]
        },
        {
            "name": "msvc-warnings-as-errors",
            "configurePreset": "msvc",
            "configuration": "WarningsAsErrors",
            "targets": ["image-processing-app"]
        },
        {
            "name": "msvc-tests",
            "configurePreset": "msvc",
            "configuration": "Tests",
            "targets": ["image-processing-app-tests"]
        },
        {
            "name": "clang-cl-debug",
            "configurePreset": "clang-cl-debug"
        },
        {
            "name": "clang-cl-release",
            "configurePreset": "clang-cl-release"
        },
        {
            "name": "clang-cl-warnings-as-errors",
            "configurePreset": "clang-cl-warnings-as-errors"
        },
        {
            "name": "clang-cl-tests",
            "configurePreset": "clang-cl-tests",
            "targets": ["image-processing-app-tests"]
        }
    ]
}
